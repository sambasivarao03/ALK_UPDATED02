package com.alk.service.validator;

import com.alk.dto.LinkageRequest;
import com.alk.dto.LinkageResponse;

import java.util.List;
import java.util.Map;
import java.util.Set;

public class RequestValidator {

    private static final Set<String> VALID_ACTIONS = Set.of("INSERT","UPDATE","DELETE","SEARCH");
    private static final Set<String> VALID_SOURCES = Set.of("AADHAAR","PAN","VOTER","DRIVING");

    public LinkageResponse validate(LinkageRequest req) {
        if (req == null) return LinkageResponse.error("Request payload cannot be null");

        if (req.getAction() == null || req.getAction().isBlank())
            return LinkageResponse.error("Action is required");

        String action = req.getAction().trim().toUpperCase();
        if (!VALID_ACTIONS.contains(action)) return LinkageResponse.error("Invalid action: " + req.getAction());

        // For INSERT/UPDATE/DELETE we need source
        if (!action.equals("SEARCH")) {
            if (req.getSource() == null || req.getSource().isBlank())
                return LinkageResponse.error("Source is required");
            if (!VALID_SOURCES.contains(req.getSource().trim().toUpperCase()))
                return LinkageResponse.error("Invalid source: " + req.getSource());
        }

        if (action.equals("INSERT") || action.equals("UPDATE")) {
            Map<String, String> data = req.getData();
            if (data == null || data.isEmpty()) return LinkageResponse.error("Data cannot be empty for INSERT/UPDATE");

            // ensure all values are strings
            for (Object v : data.values()) {
                if (!(v instanceof String)) return LinkageResponse.error("All data fields must be strings");
            }

            List<String> required = List.of("forename", "dob");
            for (String k : required) {
                if (!data.containsKey(k) || data.get(k) == null || data.get(k).isBlank()) {
                    return LinkageResponse.error(k + " is required");
                }
            }

            // Allowed keys
            Set<String> allowedKeys = Set.of(
                "forename","secondname","lastname","dob",
                "aadhaar_number","pan_number","dl_number",
                "voter_id","address","gender","mobile","email","father_name","mother_name"
            );

            for (String k : data.keySet()) {
                if (!allowedKeys.contains(k)) return LinkageResponse.error("Unknown field: " + k);
            }

            // Source-specific requirement
            String src = req.getSource().trim().toUpperCase();
            switch (src) {
                case "AADHAAR":
                    if (!data.containsKey("aadhaar_number") || !isValidAadhaar(data.get("aadhaar_number")))
                        return LinkageResponse.error("aadhaar_number is required and must be 12 digits for Aadhaar");
                    break;
                case "PAN":
                    if (!data.containsKey("pan_number") || !isValidPan(data.get("pan_number")))
                        return LinkageResponse.error("pan_number is required and must be 10 alphanumeric characters for PAN");
                    break;
                case "VOTER":
                    if (!data.containsKey("voter_id"))
                        return LinkageResponse.error("voter_id is required for Voter insert/update");
                    break;
                case "DRIVING":
                    if (!data.containsKey("dl_number"))
                        return LinkageResponse.error("dl_number is required for Driving insert/update");
                    break;
            }
        }

        // UPDATE/DELETE/SEARCH require oldAadhaarLinkageKey presence (service will still check)
        return LinkageResponse.success("VALID", null);
    }

    private boolean isValidAadhaar(String a) {
        if (a == null) return false;
        String only = a.trim();
        return only.matches("\\d{12}");
    }

    private boolean isValidPan(String p) {
        if (p == null) return false;
        return p.trim().matches("[A-Z]{5}\\d{4}[A-Z]"); // typical PAN format
    }
}






package com.alk.util;

import java.util.Locale;
import com.alk.util.HashUtil; // if HashUtil in same package adjust import

public class PiiPkGenerator {

    public static String generate(String forename, String lastname, String dob, String gender) {
        String f = normalize(forename);
        String l = normalize(lastname);
        String d = normalize(dob);
        String g = normalize(gender);
        String concat = (f == null ? "" : f) + "|" + (l == null ? "" : l) + "|" + (d == null ? "" : d) + "|" + (g == null ? "" : g);
        return HashUtil.sha256(concat);
    }

    private static String normalize(String s) {
        if (s == null) return "";
        return s.trim().toLowerCase(Locale.ROOT);
    }
}




