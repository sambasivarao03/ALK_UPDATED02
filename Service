package com.alk.service.handler;

import com.alk.model.AadhaarData;
import com.alk.model.Pii;
import com.alk.repository.AadhaarRepository;
import org.springframework.stereotype.Component;

import java.time.LocalDate;
import java.time.format.DateTimeParseException;
import java.util.Map;

@Component
public class AadhaarHandler {

    private final AadhaarRepository aadhaarRepository;

    public AadhaarHandler(AadhaarRepository aadhaarRepository) {
        this.aadhaarRepository = aadhaarRepository;
    }

    public AadhaarData saveAadhaar(Map<String,String> data, Pii pii) {
        AadhaarData a = new AadhaarData();
        a.setPii(pii);

        // set fields (conversions / parsing)
        a.setAadhaarNumber(data.get("aadhaar_number"));
        a.setForename(data.get("forename"));
        a.setMiddleName(data.get("secondname"));
        a.setLastName(data.get("lastname"));

        try {
            if (data.get("dob") != null) {
                a.setDob(LocalDate.parse(data.get("dob")));
            }
        } catch (DateTimeParseException ex) {
            // leave null — validation should have prevented bad formats
        }

        a.setGender(data.get("gender"));
        a.setAddress(data.get("address"));
        a.setParentGuardianName(data.get("parent_guardian_name"));
        a.setMobileNumber(data.get("mobile"));
        a.setEmail(data.get("email"));

        return aadhaarRepository.save(a);
    }
}




package com.alk.service.impl;

import com.alk.dto.LinkageRequest;
import com.alk.dto.LinkageResponse;
import com.alk.dto.PiiResponseDto;
import com.alk.model.Pii;
import com.alk.repository.PiiRepository;
import com.alk.service.handler.AadhaarHandler;
import com.alk.service.validator.RequestValidator;
import com.alk.util.PiiPkGenerator;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;

import java.util.*;

@Service
public class LinkageServiceImpl {

    private final PiiRepository piiRepository;
    private final AadhaarHandler aadhaarHandler;
    private final RequestValidator validator;

    public LinkageServiceImpl(PiiRepository piiRepository, AadhaarHandler aadhaarHandler) {
        this.piiRepository = piiRepository;
        this.aadhaarHandler = aadhaarHandler;
        this.validator = new RequestValidator();
    }

    @Transactional
    public LinkageResponse insert(LinkageRequest req) {
        // 1. validate
        LinkageResponse v = validator.validate(req);
        if (!"SUCCESS".equals(v.getStatus())) return v;

        Map<String,String> data = req.getData();
        String forename = data.get("forename");
        String lastname = data.get("lastname");
        String dob = data.get("dob");
        String gender = data.get("gender");

        // 2. compute piiPk
        String piiPk = PiiPkGenerator.generate(forename, lastname, dob, gender);

        Optional<Pii> opt = piiRepository.findById(piiPk);
        Pii p;
        boolean createdNew = false;

        if (opt.isPresent()) {
            p = opt.get();
        } else {
            p = new Pii();
            p.setPiiPk(piiPk);
            p.setAlk(UUID.randomUUID()); // set ALK
            p.setAadhaarCount(0);
            p.setPanCount(0);
            p.setVoterIdCount(0);
            p.setDlCount(0);
            createdNew = true;
        }

        // 3. handle source: we only implement Aadhaar here (similar handlers for other sources)
        String source = req.getSource().trim().toUpperCase();
        if ("AADHAAR".equals(source)) {
            // if new OR previous aadhaar counter 0 -> set to 1
            if (createdNew || p.getAadhaarCount() == 0) {
                p.setAadhaarCount(1);
            } else {
                // idempotent: if Aadhaar already linked, do not double increment
            }
            // save Pii first so handler can FK to managed entity
            piiRepository.save(p);

            // save/addupsert AadhaarData linked to the pii
            aadhaarHandler.saveAadhaar(data, p);
        } else {
            return LinkageResponse.error("INSERT implemented only for Aadhaar in this step");
        }

        // save Pii (counters updated)
        piiRepository.save(p);

        // build response summary
        PiiResponseDto summary = buildSummary(p);

        return LinkageResponse.success(createdNew ? "Record inserted successfully" : "Record merged", summary);
    }

    private PiiResponseDto buildSummary(Pii p) {
        List<Map<String,Object>> sources = new ArrayList<>();
        sources.add(Map.of("source","Aadhaar","counter", p.getAadhaarCount()));
        sources.add(Map.of("source","PAN","counter", p.getPanCount()));
        sources.add(Map.of("source","Voter","counter", p.getVoterIdCount()));
        sources.add(Map.of("source","Driving","counter", p.getDlCount()));
        return new PiiResponseDto(p.getAlk(), sources, p.getPiiPk());
    }
}





package com.alk.controller;

import com.alk.dto.ManageRequestDto;
import com.alk.dto.PiiResponseDto;
import com.alk.service.LinkageService;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;

@RestController
@RequestMapping("/api/v1")
public class ManageController {

    @Autowired
    private LinkageService linkageService;

    @PostMapping("/manage")
    public PiiResponseDto manage(@RequestBody ManageRequestDto request) {

        if (request.getAction() == null || request.getSource() == null) {
            throw new RuntimeException("Action and Source are mandatory");
        }

        switch (request.getAction().toUpperCase()) {

            case "INSERT":
                return linkageService.insert(request);

            case "UPDATE":
                return linkageService.update(request);

            case "DELETE":
                return linkageService.delete(request);

            case "SEARCH":
                return linkageService.search(request);

            default:
                throw new RuntimeException("Invalid action: " + request.getAction());
        }
    }
}






